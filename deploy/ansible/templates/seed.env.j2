# Context Pilot — per-unit provisioning seed. Templated by Ansible, chmod 600.
# Sourced once at boot by /etc/init.d/context-pilot. NOT in version control.
#
# The orchestrator seeds the first Admin from these values only when the user
# table is empty (idempotent), forcing a password change on first login. Add any
# provider/integration API keys below your secrets-management appends them.
CP_SEED_ADMIN_EMAIL={{ cp_seed_admin_email }}
CP_SEED_ADMIN_NAME=Admin
CP_SEED_ADMIN_PASSWORD={{ cp_seed_admin_password }}
