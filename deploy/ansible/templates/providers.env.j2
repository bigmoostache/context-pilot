# Context Pilot — provider/integration API keys for THIS client. Templated by
# Ansible from the client's (vault-encrypted) cp_provider_keys, chmod 600, sourced
# at boot by the context-pilot systemd unit (EnvironmentFile). NOT in version control.
#
# Per-client: each inventory group (client) supplies its own keys via
# group_vars/<client>/vault.yml, so two clients get different keys. Rewritten on
# every run, so rotating a client's keys = edit its vault + re-run --limit <client>.
{% for name, value in (cp_provider_keys | default({})) | dictsort %}
{{ name }}={{ value }}
{% endfor %}
