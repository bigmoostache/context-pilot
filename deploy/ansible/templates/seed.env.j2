# Context Pilot — per-unit provisioning seed. Templated by Ansible, chmod 600.
# Loaded at boot by the context-pilot systemd unit (EnvironmentFile). NOT in version control.
#
# The orchestrator seeds these accounts ONLY when the user table is empty
# (idempotent), forcing a password change on each one's first login (design
# §13.4). Two accounts, no infra knowledge required — the box is named on-site in
# the cockpit, not here:
#   • superadmin — the VENDOR god account (provider secrets; invisible to the client).
#   • admin      — the CLIENT's top account (everything but provider secrets + IT infra).
CP_SEED_SUPERADMIN_EMAIL={{ cp_seed_superadmin_email }}
CP_SEED_SUPERADMIN_NAME=Vendor
CP_SEED_SUPERADMIN_PASSWORD={{ cp_seed_superadmin_password }}
CP_SEED_ADMIN_EMAIL={{ cp_seed_admin_email }}
CP_SEED_ADMIN_NAME=Admin
CP_SEED_ADMIN_PASSWORD={{ cp_seed_admin_password }}
