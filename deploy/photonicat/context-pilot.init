#!/bin/sh /etc/rc.common
# Context Pilot orchestrator — OpenWrt procd service (Photonicat, no Docker).
#
# Install as /etc/init.d/context-pilot, then:  /etc/init.d/context-pilot enable
# Logs go to the system log: `logread -e context-pilot`.

USE_PROCD=1
# Start late (after network/dnsmasq); stop early.
START=95
STOP=10

PROG=/mnt/data/context-pilot/bin/cp-orchestrator
CP_HOME=/mnt/data/context-pilot/home
CP_WEB=/mnt/data/context-pilot/web
# Agent (cp TUI) binary the supervisor is allowed to spawn for dashboard-created
# agents. Spawned agents inherit this process's env (HOME, provider keys, …).
CP_AGENT=/mnt/data/context-pilot/bin/tui

start_service() {
    # Persisted state (registry, auth.db, central config, Claude creds, agent
    # project roots) all live under $HOME on the big data partition.
    mkdir -p "$CP_HOME"

    # Optional provisioning values (templated by Ansible, chmod 600). Sourced
    # once at boot; carries both the admin-seed vars (CP_SEED_ADMIN_*) and the
    # provider/integration API keys. The orchestrator seeds the first Admin only
    # when the user table is empty (idempotent). Provider keys placed here land
    # in the orchestrator's process env, so they (a) make agents able to use the
    # model and (b) light up the cockpit Services pane. Prefer
    # CP_SEED_ADMIN_PASSWORD_FILE so the admin secret stays out of the env.
    CP_SEED_ENV=/mnt/data/context-pilot/seed.env
    [ -f "$CP_SEED_ENV" ] && . "$CP_SEED_ENV"

    procd_open_instance
    procd_set_param command "$PROG"
    procd_set_param env \
        HOME="$CP_HOME" \
        CP_AUTH_ENABLED=1 \
        CP_ORCH_PORT=7878 \
        CP_WEB_ROOT="$CP_WEB" \
        CP_AGENT_BINARY="$CP_AGENT" \
        CP_SEED_ADMIN_EMAIL="${CP_SEED_ADMIN_EMAIL:-}" \
        CP_SEED_ADMIN_NAME="${CP_SEED_ADMIN_NAME:-}" \
        CP_SEED_ADMIN_PASSWORD="${CP_SEED_ADMIN_PASSWORD:-}" \
        CP_SEED_ADMIN_PASSWORD_FILE="${CP_SEED_ADMIN_PASSWORD_FILE:-}" \
        ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
        DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}" \
        GROQ_API_KEY="${GROQ_API_KEY:-}" \
        XAI_API_KEY="${XAI_API_KEY:-}" \
        MINIMAX_API_KEY="${MINIMAX_API_KEY:-}" \
        VOYAGE_API_KEY="${VOYAGE_API_KEY:-}" \
        DATALAB_API_KEY="${DATALAB_API_KEY:-}" \
        BRAVE_API_KEY="${BRAVE_API_KEY:-}" \
        FIRECRAWL_API_KEY="${FIRECRAWL_API_KEY:-}" \
        GITHUB_TOKEN="${GITHUB_TOKEN:-}"
    # Restart on crash, but back off if it crash-loops.
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
